<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp">

        <Spinner
            android:id="@+id/spProductos"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_margin="5dp" />

        <EditText
            android:layout_margin="5dp"
            android:id="@+id/txtCantidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Cantidad del producto"
            android:inputType="number" />

        <Button
            android:layout_margin="5dp"
            android:id="@+id/btnAgregar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AGREGAR VENTA"
            android:onClick="venta"/>

        <ListView
            android:id="@+id/lsProductosVendidos"
            android:layout_width="match_parent"
            android:layout_height="320dp" />

        <TextView
            android:layout_marginVertical="20dp"
            android:id="@+id/txtTotal"
            android:textSize="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
             />

        <TextView
            android:textSize="15dp"
            android:layout_margin="5dp"
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:gravity="center"
            android:hint="CONVERSION DE MONEDA" />

        <LinearLayout
            android:layout_gravity="center"
            android:layout_margin="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEuro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="A euro"
                android:onClick="conversionEuro"/>

            <Space
                android:layout_width="5dp"
                android:layout_height="0dp">
            </Space>

            <Button
                android:id="@+id/btnPeso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="A peso mexicano"
                android:onClick="conversionPesoMexicano"/>

            <Space
                android:layout_width="5dp"
                android:layout_height="0dp">
            </Space>

            <Button
                android:id="@+id/btnQuetzal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="A quetzal"
                android:onClick="conversionQuetzal"/>
        </LinearLayout>

        <TextView
            android:gravity="center"
            android:id="@+id/txtConversion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textSize="20dp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>